---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { withBase } from '../lib/site';

const projects = (await getCollection('projects'))
  .filter((project) => project.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout>
  <section class="hero shell">
    <div class="hero-main">
      <div class="hero-copy">
        <p class="kicker"><span class="status-dot"></span>Open to summer opportunities · Toronto</p>
        <h1>Artin Heidari</h1>
        <p class="hero-role">Incoming Queen’s Engineering student exploring robotics, embedded systems, AI, and practical software.</p>
        <div class="button-row">
          <a class="button primary" href="#work">Selected work <span aria-hidden="true">↓</span></a>
          <a class="button ghost" href="https://github.com/ArtinHeidari" rel="me noreferrer">GitHub ↗</a>
          <a class="quiet-link" href="https://www.linkedin.com/in/artinheidari/" rel="me noreferrer">LinkedIn ↗</a>
        </div>
      </div>

      <div class="engineering-mark" aria-hidden="true">
        <div class="mark-grid"></div>
        <span class="mark-label mark-label-a">INPUT</span>
        <span class="mark-label mark-label-b">BUILD</span>
        <span class="mark-label mark-label-c">TEST</span>
        <span class="mark-node node-a"></span><span class="mark-node node-b"></span><span class="mark-node node-c"></span>
        <span class="mark-line line-a"></span><span class="mark-line line-b"></span>
        <strong>AH<span>/26</span></strong>
        <p>ENGINEERING<br />SOFTWARE<br />SYSTEMS</p>
      </div>
    </div>

    <dl class="proof-strip" aria-label="Highlights">
      <div><dt>Education</dt><dd>Queen’s Engineering</dd><span>Incoming · Fall 2026</span></div>
      <div><dt>Recognition</dt><dd>Mathematics + skating</dd><span>Award recipient</span></div>
      <div><dt>Direction</dt><dd>Computer / electrical</dd><span>Robotics · AI · embedded</span></div>
    </dl>
  </section>

  <section class="section shell work-section" id="work" aria-labelledby="work-heading">
    <header class="section-title-row">
      <div><p class="section-number">01 / WORK</p><h2 id="work-heading">Selected work</h2></div>
      <a class="text-link" href={withBase('/projects/')}>Project archive <span aria-hidden="true">→</span></a>
    </header>

    <div class="project-list project-grid">
      {projects.map((project, index) => <ProjectCard project={project} index={index + 1} />)}
    </div>

    <p class="work-disclaimer"><strong>Current preview:</strong> sample entries remain clearly labelled until real projects are documented.</p>
  </section>

  <section class="section shell compact-section" id="about" aria-labelledby="about-heading">
    <header class="section-title-row">
      <div><p class="section-number">02 / PROFILE</p><h2 id="about-heading">About</h2></div>
    </header>

    <div class="about-compact">
      <div class="about-copy">
        <p class="lead">I’m interested in the point where code meets electronics and physical systems—where an idea has to work outside a demo.</p>
        <p>I’ll begin Queen’s Engineering in Fall 2026 with interests in computer and electrical engineering, robotics, embedded development, AI, and computer vision.</p>
        <p>Mathematics, skating, tutoring, piano, chess, and robotics have shaped how I approach difficult work: stay disciplined, communicate clearly, and keep iterating.</p>
      </div>
      <div class="interest-groups">
        <div><span>Build</span><strong>Software · hardware · prototypes</strong></div>
        <div><span>Explore</span><strong>Robotics · AI · computer vision</strong></div>
        <div><span>Develop</span><strong>Technical depth · teamwork · communication</strong></div>
      </div>
    </div>
  </section>

  <section class="section shell compact-section" id="contact" aria-labelledby="contact-heading">
    <header class="section-title-row">
      <div><p class="section-number">03 / CONNECT</p><h2 id="contact-heading">Contact</h2></div>
      <span class="availability"><i class="status-dot"></i>Open to Work</span>
    </header>

    <div class="contact-compact">
      <p>I’m looking for summer opportunities where I can learn quickly, contribute, and work on real technical problems.</p>
      <div class="contact-actions">
        <a class="button primary" href="https://www.linkedin.com/in/artinheidari/" rel="me noreferrer">LinkedIn ↗</a>
        <a class="button ghost" href="https://github.com/ArtinHeidari" rel="me noreferrer">GitHub ↗</a>
        <span>Toronto, Ontario, Canada</span>
      </div>
    </div>
  </section>
</BaseLayout>
