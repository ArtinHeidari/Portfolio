---
import { withBase } from '../lib/site';

const navigation = [
  { label: 'Work', href: withBase('/projects/') },
  { label: 'Writing', href: withBase('/blog/') },
  { label: 'About', href: withBase('/#about') },
  { label: 'Contact', href: withBase('/#contact') },
];
---

<header class="site-header">
  <div class="shell nav-shell">
    <a class="wordmark" href={withBase('/')} aria-label="Artin Heidari home">AH<span>.</span></a>
    <nav aria-label="Primary navigation">
      <ul class="nav-list">
        {navigation.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
      </ul>
    </nav>
    <div class="nav-actions">
      <span class="status-pill"><span class="status-dot"></span>Open to Work</span>
      <button class="theme-toggle" type="button" data-theme-toggle aria-label="Switch colour mode">DARK</button>
    </div>
  </div>
</header>
