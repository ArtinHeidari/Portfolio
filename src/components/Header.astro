---
import { withBase } from '../lib/site';

const navigation = [
  { label: 'Projects', href: withBase('/#work'), mobileOnly: false },
  { label: 'About', href: withBase('/#about'), mobileOnly: false },
  { label: 'Contact', href: withBase('/#contact'), mobileOnly: true },
];
---

<header class="site-header">
  <div class="shell nav-shell">
    <a class="wordmark" href={withBase('/')} aria-label="Artin Heidari home">AH<span>.</span></a>
    <nav aria-label="Primary navigation">
      <ul class="nav-list">
        {navigation.map((item) => <li class:list={{ 'mobile-nav-item': item.mobileOnly }}><a data-nav-link href={item.href}>{item.label}</a></li>)}
      </ul>
    </nav>
    <div class="nav-actions">
      <button class="search-trigger" type="button" data-command-open aria-label="Open site search">
        <svg aria-hidden="true" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"></circle><path d="m16 16 4 4"></path></svg>
        <kbd data-command-shortcut>Ctrl K</kbd>
      </button>
      <button class="theme-toggle" type="button" data-theme-toggle aria-label="Switch colour mode">LIGHT</button>
      <a class="nav-contact" data-nav-link href={withBase('/#contact')}>Contact</a>
    </div>
  </div>
</header>
